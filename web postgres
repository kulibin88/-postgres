        self.db_var = tk.StringVar(value=self.config.get("DB", "database", fallback=""))
        self.user_var = tk.StringVar(value=self.config.get("DB", "user", fallback=""))
        self.pwd_var = tk.StringVar(value=self.config.get("DB", "password", fallback=""))

