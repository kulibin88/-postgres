                        col = col_combo.get()
                        if not expr:
                            messagebox.showwarning("Предупреждение", "Введите выражение CHECK.")
                            return
                        full_expr = f"{col} {expr}"
                        self.cur.execute(sql.SQL("""
                            ALTER TABLE {}.{} ADD CONSTRAINT {} CHECK ({})
                        """).format(
                            sql.Identifier(schema),
                            sql.Identifier(table),
                            sql.Identifier(cons_name),
                            sql.SQL(full_expr)
                        ))
