        self.host_entry.grid(row=0, column=1, padx=5, pady=5)
        enable_copy_paste(self.host_entry)

        ttk.Label(self.root, text="Порт:").grid(row=1, column=0, padx=5, pady=5, sticky="e")
        self.port_entry = ttk.Entry(self.root, textvariable=self.port_var, width=30)
        self.port_entry.grid(row=1, column=1, padx=5, pady=5)
        enable_copy_paste(self.port_entry)

