    def drop_constraint(self):
        schema = self.manage_schema_combo.get()
        table = self.manage_table_combo.get()
        if not schema or not table:
            messagebox.showwarning("Предупреждение", "Выберите таблицу.")
            return
        try:
            self.cur.execute("""
                SELECT conname, contype
                FROM pg_constraint
                WHERE conrelid = %s::regclass
                AND contype IN ('c', 'u', 'p', 'f')
            """, (f"{schema}.{table}",))
            constraints = [(row[0], row[1]) for row in self.cur.fetchall()]
            self.cur.execute("""
                SELECT column_name
                FROM information_schema.columns
                WHERE table_schema = %s AND table_name = %s AND is_nullable = 'NO'
            """, (schema, table))
            not_null_cols = [row[0] for row in self.cur.fetchall()]
            constraint_list = []
            for name, type_ in constraints:
                type_desc = {'c': 'CHECK', 'u': 'UNIQUE', 'p': 'PRIMARY KEY', 'f': 'FOREIGN KEY'}.get(type_, type_)
                constraint_list.append(f"{name} ({type_desc})")
            for col in not_null_cols:
                constraint_list.append(f"NOT NULL ({col})")
            if not constraint_list:
                messagebox.showinfo("Информация", "Нет ограничений для удаления.")
                return
            dialog = tk.Toplevel(self.root)
            dialog.transient(self.root)
            dialog.attributes('-topmost', True)
            dialog.after(200, lambda: dialog.attributes('-topmost', False))
            dialog.title("Удаление ограничения")
            dialog.geometry("400x200")

            ttk.Label(dialog, text="Выберите ограничение:").pack(pady=5)
            constraint_var = tk.StringVar()
            combo = ttk.Combobox(dialog, textvariable=constraint_var, values=constraint_list, state="readonly", width=50)
            combo.pack(pady=5)
            if constraint_list:
                combo.current(0)

            def do_drop():
                selected = constraint_var.get()
                if not selected:
                    return
                try:
                    with self.conn:
                        if selected.startswith("NOT NULL"):
                            col_name = selected.split("(")[1].rstrip(")")
                            self.cur.execute(sql.SQL("""
                                ALTER TABLE {}.{} ALTER COLUMN {} DROP NOT NULL
                            """).format(
                                sql.Identifier(schema),
                                sql.Identifier(table),
                                sql.Identifier(col_name)
                            ))
                        else:
                            cons_name = selected.split(" ")[0]
                            self.cur.execute(sql.SQL("""
                                ALTER TABLE {}.{} DROP CONSTRAINT {}
                            """).format(
                                sql.Identifier(schema),
                                sql.Identifier(table),
                                sql.Identifier(cons_name)
                            ))
                    messagebox.showinfo("Успех", "Ограничение удалено.")
                    dialog.destroy()
                    self.load_table_columns()
                except psycopg2.errors.UndefinedObject:
                    self.conn.rollback()
                    messagebox.showerror("Ошибка", f"Ограничение '{cons_name}' не найдено.\nОбновите список таблиц.")
                except Exception as e:
                    self.conn.rollback()
                    messagebox.showerror("Ошибка", f"Не удалось удалить: {e}")

            ttk.Button(dialog, text="Удалить", command=do_drop).pack(pady=10)
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Ошибка: {e}")

