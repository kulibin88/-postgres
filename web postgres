    def toggle_range(self):
        if self.data_filter_mode_var.get() == "range":
            self.filter_value_entry.config(state="disabled")
            self.filter_range_from.config(state="normal")
            self.filter_range_to.config(state="normal")
        else:
            self.filter_value_entry.config(state="normal")
            self.filter_range_from.config(state="disabled")
            self.filter_range_to.config(state="disabled")
            self.filter_value_entry.focus_set()

    def build_where_clause(self):
        if not self.current_data_schema or not self.current_data_table:
            return None, []
        column = self.filter_column_combo.get()
        if not column:
            return None, []
        if self.data_filter_mode_var.get() == "range":
            from_val = self.filter_range_from.get().strip()
            to_val = self.filter_range_to.get().strip()
            if not from_val and not to_val:
                return None, []
            conditions = []
            params = []
            if from_val:
                conditions.append(sql.SQL("{} >= {}").format(sql.Identifier(column), sql.Placeholder()))
                params.append(from_val)
            if to_val:
                conditions.append(sql.SQL("{} <= {}").format(sql.Identifier(column), sql.Placeholder()))
                params.append(to_val)
            return sql.SQL(" AND ").join(conditions), params
        else:
            value = self.filter_value_entry.get().strip()
            if not value:
                return None, []
            return sql.SQL("{} = {}").format(sql.Identifier(column), sql.Placeholder()), [value]

    def apply_filter(self):
        self.offset_var.set(0)
        self.load_table_data()

    def reset_filter(self):
        self.filter_column_combo.set('')
        self.filter_value_entry.delete(0, tk.END)
        self.data_filter_mode_var.set("exact")
        self.filter_range_from.delete(0, tk.END)
        self.filter_range_to.delete(0, tk.END)
        self.toggle_range()
        self.apply_filter()

    def load_table_data(self):
        schema = self.data_schema_combo.get()
        table = self.data_table_combo.get()
        if not schema or not table:
            messagebox.showwarning("Предупреждение", "Выберите схему и таблицу.")
            return
        self.current_data_schema = schema
        self.current_data_table = table
        try:
            self.cur.execute("""
                SELECT
                c.column_name,
                c.data_type,
                c.is_nullable,
                c.column_default,
                tc.constraint_type
                FROM information_schema.columns c
                LEFT JOIN information_schema.key_column_usage kcu
                ON kcu.table_schema = c.table_schema
                AND kcu.table_name = c.table_name
                AND kcu.column_name = c.column_name
                LEFT JOIN information_schema.table_constraints tc
                ON tc.table_schema = kcu.table_schema
                AND tc.table_name = kcu.table_name
                AND tc.constraint_name = kcu.constraint_name
                WHERE c.table_schema = %s AND c.table_name = %s
                ORDER BY c.ordinal_position
            """, (schema, table))
            cols_info = self.cur.fetchall()
            self.data_columns = []
            self.data_types = {}
            self.column_constraints = {}
            for col in cols_info:
                col_name = col[0]
                self.data_columns.append(col_name)
                self.data_types[col_name] = col[1]
                constraints = []
                if col[2] == 'NO':
                    constraints.append("NOT NULL")
                if col[4] == 'PRIMARY KEY':
                    constraints.append("PRIMARY KEY")
                elif col[4] == 'UNIQUE':
                    constraints.append("UNIQUE")
                self.column_constraints[col_name] = ", ".join(constraints) if constraints else "Нет"
            self.filter_column_combo['values'] = self.data_columns
            self.data_sort_col['values'] = self.data_columns
            where_clause, where_params = self.build_where_clause()
            self.current_where_clause = where_clause
            self.current_where_params = where_params
            count_query = sql.SQL("SELECT COUNT(*) FROM {}.{}").format(
                sql.Identifier(schema), sql.Identifier(table))
            if where_clause:
                count_query = sql.SQL("{} WHERE {}").format(count_query, where_clause)
            if where_clause:
                self.cur.execute(count_query, where_params)
            else:
                self.cur.execute(count_query)
            self.total_rows = self.cur.fetchone()[0]
            self.total_label.config(text=str(self.total_rows))
            limit = self.limit_var.get()
            offset = self.offset_var.get()
            if offset >= self.total_rows:
                offset = max(0, self.total_rows - limit)
            self.offset_var.set(offset)
            sort_col = self.data_sort_col.get()
            sort_order = self.data_sort_order.get()
            order_by = None
            if sort_col and sort_col in self.data_columns:
                order_by = sql.SQL("ORDER BY {} {}").format(sql.Identifier(sort_col), sql.SQL(sort_order))
            query = sql.SQL("SELECT * FROM {}.{}").format(sql.Identifier(schema), sql.Identifier(table))
            if where_clause:
                query = sql.SQL("{} WHERE {}").format(query, where_clause)
            if order_by:
                query = sql.SQL("{} {}").format(query, order_by)
            if limit > 0:
                query = sql.SQL("{} LIMIT {} OFFSET {}").format(query, sql.Literal(limit), sql.Literal(offset))
            if where_clause:
                self.cur.execute(query, where_params)
            else:
                self.cur.execute(query)
            rows = self.cur.fetchall()
            self.display_data_rows(rows, offset)
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить данные:\n{e}")

    def display_data_rows(self, rows, offset):
        for item in self.data_tree.get_children():
            self.data_tree.delete(item)
        columns_with_number = ["№"] + self.data_columns
        self.data_tree["columns"] = columns_with_number
        for col in columns_with_number:
            self.data_tree.heading(col, text=col)
        for i, row in enumerate(rows):
            row_num = offset + i + 1
            values = [row_num]
            for col in self.data_columns:
                val = row[col]
                values.append("" if val is None else str(val))
            tag = "even" if i % 2 == 0 else "odd"
            self.data_tree.insert("", "end", values=values, tags=(tag,))
        self.auto_columns(self.data_tree, columns_with_number)

    def prev_page(self):
        limit = self.limit_var.get()
        offset = self.offset_var.get() - limit
        if offset < 0:
            offset = 0
        self.offset_var.set(offset)
        self.load_table_data()

    def next_page(self):
        limit = self.limit_var.get()
        offset = self.offset_var.get() + limit
        if offset >= self.total_rows:
            offset = max(0, self.total_rows - limit)
        self.offset_var.set(offset)
        self.load_table_data()

    def get_selected_record(self):
        selected = self.data_tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите запись.")
            return None
        item = selected[0]
        values = self.data_tree.item(item, "values")
        if not values or len(values) <= 1:
            return None
        return values[1:]

    def add_record(self):
        self.open_record_dialog(is_edit=False)

    def edit_record(self):
        selected_values = self.get_selected_record()
        if not selected_values:
            return
        self.open_record_dialog(is_edit=True, initial_values=selected_values, old_values=list(selected_values))

    def delete_record(self):
        if not self.current_data_schema or not self.current_data_table:
            messagebox.showwarning("Предупреждение", "Сначала загрузите таблицу.")
            return
        selected_values = self.get_selected_record()
        if not selected_values:
            return
        if not messagebox.askyesno("Подтверждение", "Удалить выбранную запись?"):
            return
        try:
            where_parts = []
            where_params = []
            for i, col in enumerate(self.data_columns):
                val = selected_values[i]
                if val is None or val == "":
                    where_parts.append(sql.SQL("{} IS NULL").format(sql.Identifier(col)))
                else:
                    where_parts.append(sql.SQL("{} = {}").format(sql.Identifier(col), sql.Placeholder()))
                    where_params.append(val)
            where_clause = sql.SQL(" AND ").join(where_parts)
            query = sql.SQL("DELETE FROM {}.{} WHERE {}").format(
                sql.Identifier(self.current_data_schema),
                sql.Identifier(self.current_data_table),
                where_clause
            )
            with self.conn:
                self.cur.execute(query, where_params)
            messagebox.showinfo("Успех", "Запись удалена.")
            self.load_table_data()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось удалить запись:\n{e}")

    def open_record_dialog(self, is_edit=False, initial_values=None, old_values=None):
        if is_edit and old_values is None:
            return
        dialog = tk.Toplevel(self.root)
        dialog.transient(self.root)
        dialog.attributes('-topmost', True)
        dialog.after(200, lambda: dialog.attributes('-topmost', False))
        dialog.title("Редактирование записи" if is_edit else "Добавление записи")
        dialog.geometry("600x450")
        dialog.resizable(True, True)

        main_frame = ttk.Frame(dialog)
        main_frame.pack(fill="both", expand=True, padx=5, pady=5)

        canvas = tk.Canvas(main_frame, highlightthickness=0)
        scrollbar = ttk.Scrollbar(main_frame, orient="vertical", command=canvas.yview)
        inner_frame = ttk.Frame(canvas)
        canvas.create_window((0, 0), window=inner_frame, anchor="nw")
        canvas.configure(yscrollcommand=scrollbar.set)
        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")

        entries = {}
        ttk.Label(inner_frame, text="Колонка", font=("TkDefaultFont", 9, "bold")).grid(row=0, column=0, padx=5, pady=2)
        ttk.Label(inner_frame, text="Тип", font=("TkDefaultFont", 9, "bold")).grid(row=0, column=1, padx=5, pady=2)
        ttk.Label(inner_frame, text="Ограничения", font=("TkDefaultFont", 9, "bold")).grid(row=0, column=2, padx=5, pady=2)
        ttk.Label(inner_frame, text="Значение", font=("TkDefaultFont", 9, "bold")).grid(row=0, column=3, padx=5, pady=2)

        row = 1
        for i, col in enumerate(self.data_columns):
            col_type = self.data_types.get(col, "unknown")
            constraints = self.column_constraints.get(col, "")
            ttk.Label(inner_frame, text=col).grid(row=row, column=0, padx=5, pady=2, sticky="e")
            ttk.Label(inner_frame, text=col_type).grid(row=row, column=1, padx=5, pady=2, sticky="w")
            ttk.Label(inner_frame, text=constraints).grid(row=row, column=2, padx=5, pady=2, sticky="w")
            var = tk.StringVar()
            if initial_values and i < len(initial_values):
                val = initial_values[i]
                if val == "None":
                    val = ""
                var.set(val)
            entry = ttk.Entry(inner_frame, textvariable=var, width=40)
            entry.grid(row=row, column=3, padx=5, pady=2, sticky="ew")
            enable_copy_paste(entry)
            entries[col] = var
            row += 1

        inner_frame.columnconfigure(3, weight=1)
        inner_frame.update_idletasks()
        canvas.configure(scrollregion=canvas.bbox("all"))

        def save():
            new_values = []
            for col in self.data_columns:
                val = entries[col].get().strip()
                if val == "":
                    new_values.append(None)
                else:
                    new_values.append(val)
            if is_edit:
                set_parts = []
                for col in self.data_columns:
                    set_parts.append(sql.SQL("{} = {}").format(sql.Identifier(col), sql.Placeholder()))
                set_clause = sql.SQL(", ").join(set_parts)
                where_parts = []
                where_params = []
                for i, col in enumerate(self.data_columns):
                    val = old_values[i]
                    if val is None or val == "":
                        where_parts.append(sql.SQL("{} IS NULL").format(sql.Identifier(col)))
                    else:
                        where_parts.append(sql.SQL("{} = {}").format(sql.Identifier(col), sql.Placeholder()))
                        where_params.append(val)
                where_clause = sql.SQL(" AND ").join(where_parts)
                query = sql.SQL("UPDATE {}.{} SET {} WHERE {}").format(
                    sql.Identifier(self.current_data_schema),
                    sql.Identifier(self.current_data_table),
                    set_clause,
                    where_clause
                )
                try:
                    with self.conn:
                        self.cur.execute(query, new_values + where_params)
                    messagebox.showinfo("Успех", "Запись обновлена.")
                    dialog.destroy()
                    self.load_table_data()
                except Exception as e:
                    self.conn.rollback()
                    messagebox.showerror("Ошибка", f"Не удалось обновить запись:\n{e}")
            else:
                placeholders = sql.SQL(", ").join([sql.Placeholder()] * len(self.data_columns))
                query = sql.SQL("INSERT INTO {}.{} ({}) VALUES ({})").format(
                    sql.Identifier(self.current_data_schema),
                    sql.Identifier(self.current_data_table),
                    sql.SQL(", ").join(map(sql.Identifier, self.data_columns)),
                    placeholders
                )
                try:
                    with self.conn:
                        self.cur.execute(query, new_values)
                    messagebox.showinfo("Успех", "Запись добавлена.")
                    dialog.destroy()
                    self.load_table_data()
                except Exception as e:
                    self.conn.rollback()
                    messagebox.showerror("Ошибка", f"Не удалось добавить запись:\n{e}")

        btn_frame = ttk.Frame(dialog)
        btn_frame.pack(pady=5)
        ttk.Button(btn_frame, text="Сохранить", command=save).pack(side="left", padx=5)
        ttk.Button(btn_frame, text="Отмена", command=dialog.destroy).pack(side="left", padx=5)

    def show_copy_menu(self, event):
        item = self.data_tree.identify_row(event.y)
        if not item:
            return
        column = self.data_tree.identify_column(event.x)
        column_index = int(column[1:]) - 1 if column else None
        menu = tk.Menu(self.root, tearoff=0)
        if column_index is not None and 0 <= column_index < len(self.data_columns) + 1:
            menu.add_command(label="Копировать ячейку", command=lambda: self.copy_cell(item, column_index))
            menu.add_command(label="Копировать строку", command=lambda: self.copy_row(item))
        menu.post(event.x_root, event.y_root)

    def copy_cell(self, item, column_index):
        values = self.data_tree.item(item, "values")
        if values and column_index < len(values):
            self.root.clipboard_clear()
            self.root.clipboard_append(str(values[column_index]))

    def copy_row(self, item):
        values = self.data_tree.item(item, "values")
        if values:
            row_text = "\t".join(str(v) for v in values)
            self.root.clipboard_clear()
            self.root.clipboard_append(row_text)

    def copy_selected_row(self, event):
        selected = self.data_tree.selection()
        if selected:
            self.copy_row(selected[0])

    def load_data_schemas(self):
        try:
            self.cur.execute("""
                SELECT schema_name
                FROM information_schema.schemata
                WHERE schema_name NOT IN ('pg_catalog', 'information_schema')
                AND schema_name NOT LIKE 'pg_temp%'
                AND schema_name NOT LIKE 'pg_toast%'
                ORDER BY schema_name
            """)
            schemas = [row[0] for row in self.cur.fetchall()]
            self.data_schema_combo['values'] = schemas
            if schemas:
                self.data_schema_combo.current(0)
                self.load_tables_for_data_schema(schemas[0])
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить список схем:\n{e}")

    def on_data_schema_selected(self, event=None):
        schema = self.data_schema_combo.get()
        self.load_tables_for_data_schema(schema)

    def load_tables_for_data_schema(self, schema_name):
        try:
            self.cur.execute("""
                SELECT table_name
                FROM information_schema.tables
                WHERE table_schema = %s
                AND table_type = 'BASE TABLE'
                ORDER BY table_name
            """, (schema_name,))
            tables = [row[0] for row in self.cur.fetchall()]
            self.data_table_combo['values'] = tables
            if tables:
                self.data_table_combo.current(0)
            else:
                self.data_table_combo.set('')
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить список таблиц:\n{e}")


