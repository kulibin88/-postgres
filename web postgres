    def load_view_schemas(self):
        try:
            self.cur.execute("""
                SELECT schema_name
                FROM information_schema.schemata
                WHERE schema_name NOT IN ('pg_catalog', 'information_schema')
                AND schema_name NOT LIKE 'pg_temp%'
                AND schema_name NOT LIKE 'pg_toast%'
                ORDER BY schema_name
            """)
            schemas = [row[0] for row in self.cur.fetchall()]
            self.schema_combo['values'] = schemas
            if schemas:
                self.schema_combo.current(0)
                self.load_view_objects(schemas[0])
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить список схем:\n{e}")

    def load_view_objects(self, schema_name):
        try:
            self.cur.execute("""
                SELECT table_name
                FROM information_schema.tables
                WHERE table_schema = %s
                AND table_type IN ('BASE TABLE', 'VIEW')
                ORDER BY table_name
            """, (schema_name,))
            objects = [row[0] for row in self.cur.fetchall()]
            self.view_table_combo['values'] = objects
            if objects:
                self.view_table_combo.current(0)
                self.load_view_columns(schema_name, objects[0])
            else:
                self.view_table_combo.set('')
                self.view_filter_col['values'] = []
                self.view_sort_col['values'] = []
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить список объектов:\n{e}")

    def load_view_columns(self, schema_name, object_name):
        try:
            self.cur.execute("""
                SELECT column_name
                FROM information_schema.columns
                WHERE table_schema = %s AND table_name = %s
                ORDER BY ordinal_position
            """, (schema_name, object_name))
            self.view_columns = [row[0] for row in self.cur.fetchall()]
            self.view_filter_col['values'] = self.view_columns
            self.view_sort_col['values'] = self.view_columns
            if self.view_columns:
                self.view_sort_col.current(0)
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить колонки:\n{e}")

    def on_view_schema_selected(self, event=None):
        schema = self.schema_combo.get()
        self.load_view_objects(schema)

    def on_view_table_selected(self, event=None):
        schema = self.schema_combo.get()
        obj = self.view_table_combo.get()
        if schema and obj:
            self.load_view_columns(schema, obj)

    def toggle_range_view(self):
        if self.filter_mode_var.get() == "range":
            self.view_filter_val.config(state="disabled")
            self.view_range_from.config(state="normal")
            self.view_range_to.config(state="normal")
        else:
            self.view_filter_val.config(state="normal")
            self.view_range_from.config(state="disabled")
            self.view_range_to.config(state="disabled")
            self.view_filter_val.focus_set()

    def build_view_where(self):
        col = self.view_filter_col.get()
        if not col:
            return None, []
        if self.filter_mode_var.get() == "range":
            from_val = self.view_range_from.get().strip()
            to_val = self.view_range_to.get().strip()
            if not from_val and not to_val:
                return None, []
            cond = []
            params = []
            if from_val:
                cond.append(sql.SQL("{} >= {}").format(sql.Identifier(col), sql.Placeholder()))
                params.append(from_val)
            if to_val:
                cond.append(sql.SQL("{} <= {}").format(sql.Identifier(col), sql.Placeholder()))
                params.append(to_val)
            return sql.SQL(" AND ").join(cond), params
        else:
            val = self.view_filter_val.get().strip()
            if not val:
                return None, []
            return sql.SQL("{} = {}").format(sql.Identifier(col), sql.Placeholder()), [val]

    def load_view_table(self):
        schema = self.schema_combo.get()
        obj = self.view_table_combo.get()
        if not schema or not obj:
            messagebox.showwarning("Предупреждение", "Выберите схему и объект.")
            return
        try:
            self.cur.execute("""
                SELECT column_name
                FROM information_schema.columns
                WHERE table_schema = %s AND table_name = %s
                ORDER BY ordinal_position
            """, (schema, obj))
            columns = [row[0] for row in self.cur.fetchall()]
            where_clause, where_params = self.build_view_where()
            limit = self.view_limit_var.get()
            sort_col = self.view_sort_col.get()
            sort_order = self.view_sort_order.get()
            order_by = None
            if sort_col and sort_col in columns:
                order_by = sql.SQL("ORDER BY {} {}").format(sql.Identifier(sort_col), sql.SQL(sort_order))
            query = sql.SQL("SELECT * FROM {}.{}").format(sql.Identifier(schema), sql.Identifier(obj))
            if where_clause:
                query = sql.SQL("{} WHERE {}").format(query, where_clause)
            if order_by:
                query = sql.SQL("{} {}").format(query, order_by)
            if limit > 0:
                query = sql.SQL("{} LIMIT {}").format(query, sql.Literal(limit))
            if where_clause:
                self.cur.execute(query, where_params)
            else:
                self.cur.execute(query)
            rows = self.cur.fetchall()
            self.display_search_results(rows, columns)
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить данные:\n{e}")

    def reset_view_filter(self):
        self.view_filter_col.set('')
        self.view_filter_val.delete(0, tk.END)
        self.filter_mode_var.set("exact")
        self.view_range_from.delete(0, tk.END)
        self.view_range_to.delete(0, tk.END)
        self.toggle_range_view()
        self.load_view_table()

    def toggle_extra_range(self):
        if self.extra_filter_mode_var.get() == "range":
            self.extra_filter_val.config(state="disabled")
            self.extra_range_from.config(state="normal")
            self.extra_range_to.config(state="normal")
        else:
            self.extra_filter_val.config(state="normal")
            self.extra_range_from.config(state="disabled")
            self.extra_range_to.config(state="disabled")
            self.extra_filter_val.focus_set()

    def build_extra_where(self):
        col = self.extra_filter_col.get()
        if not col:
            return None, []
        if self.extra_filter_mode_var.get() == "range":
            from_val = self.extra_range_from.get().strip()
            to_val = self.extra_range_to.get().strip()
            if not from_val and not to_val:
                return None, []
            cond = []
            params = []
            if from_val:
                cond.append(sql.SQL("{} >= {}").format(sql.Identifier(col), sql.Placeholder()))
                params.append(from_val)
            if to_val:
                cond.append(sql.SQL("{} <= {}").format(sql.Identifier(col), sql.Placeholder()))
                params.append(to_val)
            return sql.SQL(" AND ").join(cond), params
        else:
            val = self.extra_filter_val.get().strip()
            if not val:
                return None, []
            return sql.SQL("{} = {}").format(sql.Identifier(col), sql.Placeholder()), [val]

    def search_in_table(self):
        search_text = self.search_var.get().strip()
        if not search_text:
            messagebox.showwarning("Предупреждение", "Введите поисковый запрос.")
            return
        if hasattr(self, 'current_selected_table') and self.current_selected_table:
            schema, obj = self.current_selected_table
        else:
            schema = self.schema_combo.get()
            obj = self.view_table_combo.get()
        if not schema or not obj:
            messagebox.showwarning("Предупреждение", "Выберите объект.")
            return
        try:
            self.cur.execute("""
                SELECT column_name
                FROM information_schema.columns
                WHERE table_schema = %s AND table_name = %s
            """, (schema, obj))
            all_cols = [row[0] for row in self.cur.fetchall()]
            conditions = []
            for col in all_cols:
                conditions.append(sql.SQL("CAST({} AS TEXT) LIKE %s ESCAPE '\\'").format(sql.Identifier(col)))
            main_condition = sql.SQL(" OR ").join(conditions)
            search_pattern = search_text.replace('\\', '\\\\').replace('%', '\\%').replace('_', '\\_')
            search_pattern = f"%{search_pattern}%"
            main_params = [search_pattern] * len(all_cols)
            extra_where, extra_params = self.build_extra_where()
            if extra_where:
                final_where = sql.SQL("({}) AND ({})").format(main_condition, extra_where)
                params = main_params + extra_params
            else:
                final_where = main_condition
                params = main_params
            sort_col = self.search_sort_col.get()
            sort_order = self.search_sort_order.get()
            order_by = None
            if sort_col and sort_col in all_cols:
                order_by = sql.SQL("ORDER BY {} {}").format(sql.Identifier(sort_col), sql.SQL(sort_order))
            query = sql.SQL("SELECT * FROM {}.{} WHERE {}").format(
                sql.Identifier(schema), sql.Identifier(obj), final_where)
            if order_by:
                query = sql.SQL("{} {}").format(query, order_by)
            limit = self.search_limit_var.get()
            if limit > 0:
                query = sql.SQL("{} LIMIT {}").format(query, sql.Literal(limit))
            self.cur.execute(query, params)
            rows = self.cur.fetchall()
            if rows:
                columns = [desc[0] for desc in self.cur.description]
                self.display_search_results(rows, columns)
            else:
                messagebox.showinfo("Результат", "Ничего не найдено.")
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Ошибка при поиске:\n{e}")

    def search_all_db(self):
        search_text = self.search_var.get().strip()
        if not search_text:
            messagebox.showwarning("Предупреждение", "Введите поисковый запрос.")
            return
        extra_where, extra_params = self.build_extra_where()
        search_pattern = search_text.replace('\\', '\\\\').replace('%', '\\%').replace('_', '\\_')
        search_pattern = f"%{search_pattern}%"
        try:
            self.cur.execute("""
                SELECT table_schema, table_name
                FROM information_schema.tables
                WHERE table_schema NOT IN ('pg_catalog', 'information_schema')
                AND table_schema NOT LIKE 'pg_temp%'
                AND table_schema NOT LIKE 'pg_toast%'
                AND table_type IN ('BASE TABLE', 'VIEW')
                ORDER BY table_schema, table_name
            """)
            objects = [(row[0], row[1]) for row in self.cur.fetchall()]
            self.current_found_results = []
            self.found_tables_listbox.delete(0, tk.END)
            limit = self.search_limit_var.get()
            for schema, obj in objects:
                self.cur.execute("""
                    SELECT column_name
                    FROM information_schema.columns
                    WHERE table_schema = %s AND table_name = %s
                """, (schema, obj))
                all_cols = [row[0] for row in self.cur.fetchall()]
                conditions = []
                for col in all_cols:
                    conditions.append(sql.SQL("CAST({} AS TEXT) LIKE %s ESCAPE '\\'").format(sql.Identifier(col)))
                main_condition = sql.SQL(" OR ").join(conditions)
                main_params = [search_pattern] * len(all_cols)
                if extra_where:
                    final_where = sql.SQL("({}) AND ({})").format(main_condition, extra_where)
                    params = main_params + extra_params
                else:
                    final_where = main_condition
                    params = main_params
                query = sql.SQL("SELECT * FROM {}.{} WHERE {}").format(
                    sql.Identifier(schema), sql.Identifier(obj), final_where)
                if limit > 0:
                    query = sql.SQL("{} LIMIT {}").format(query, sql.Literal(limit))
                self.cur.execute(query, params)
                rows = self.cur.fetchall()
                if rows:
                    columns = [desc[0] for desc in self.cur.description]
                    self.current_found_results.append((schema, obj, rows, columns))
                    self.found_tables_listbox.insert(tk.END, f"{schema}.{obj} ({len(rows)} записей)")
            if not self.current_found_results:
                messagebox.showinfo("Результат", "Ничего не найдено.")
                self.selected_table_label.config(text="Выбрана таблица/представление: не выбрано")
                self.extra_filter_col['values'] = []
                self.search_sort_col['values'] = []
                return
            if len(self.current_found_results) == 1:
                self.found_tables_listbox.selection_set(0)
                self.on_found_table_selected()
            else:
                self.selected_table_label.config(text="Выберите объект из списка")
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Ошибка при поиске:\n{e}")

    def on_found_table_selected(self, event=None):
        selection = self.found_tables_listbox.curselection()
        if not selection:
            return
        idx = selection[0]
        schema, obj, rows, columns = self.current_found_results[idx]
        self.display_search_results(rows, columns)
        self.current_selected_table = (schema, obj)
        self.selected_table_label.config(text=f"Выбрано: {schema}.{obj}")
        try:
            self.cur.execute("""
                SELECT column_name
                FROM information_schema.columns
                WHERE table_schema = %s AND table_name = %s
            """, (schema, obj))
            all_cols = [row[0] for row in self.cur.fetchall()]
            self.search_sort_col['values'] = all_cols
            if all_cols:
                self.search_sort_col.current(0)
            self.extra_filter_col['values'] = all_cols
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить колонки:\n{e}")
        self._sync_extra_filter_to_view()

    def _sync_extra_filter_to_view(self):
        col = self.extra_filter_col.get()
        if col:
            self.view_filter_col.set(col)
        else:
            self.view_filter_col.set('')
        if self.extra_filter_mode_var.get() == "range":
            self.filter_mode_var.set("range")
            self.toggle_range_view()
            self.view_range_from.delete(0, tk.END)
            self.view_range_from.insert(0, self.extra_range_from.get())
            self.view_range_to.delete(0, tk.END)
            self.view_range_to.insert(0, self.extra_range_to.get())
        else:
            self.filter_mode_var.set("exact")
            self.toggle_range_view()
            self.view_filter_val.delete(0, tk.END)
            self.view_filter_val.insert(0, self.extra_filter_val.get())

    def auto_columns(self, tree, columns):
        default_font = tkfont.nametofont("TkDefaultFont")
        heading_font = default_font
        for col in columns:
            header_text = tree.heading(col, "text") or col
            header_width = heading_font.measure(header_text) + 40
            max_data_width = header_width
            for child in tree.get_children():
                value = tree.set(child, col)
                if value:
                    value_width = default_font.measure(str(value)) + 20
                    max_data_width = max(max_data_width, value_width)
            tree.column(col, width=max_data_width, minwidth=header_width, stretch=False)
        tree.update_idletasks()

    def display_search_results(self, rows, columns):
        for item in self.result_tree.get_children():
            self.result_tree.delete(item)
        self.result_tree["columns"] = columns
        for col in columns:
            self.result_tree.heading(col, text=col)
        for i, row in enumerate(rows):
            values = [row[col] for col in columns]
            tag = "even" if i % 2 == 0 else "odd"
            self.result_tree.insert("", "end", values=values, tags=(tag,))
        self.auto_columns(self.result_tree, columns)

    def show_search_copy_menu(self, event):
        item = self.result_tree.identify_row(event.y)
        if not item:
            return
        column = self.result_tree.identify_column(event.x)
        column_index = int(column[1:]) - 1 if column else None
        menu = tk.Menu(self.root, tearoff=0)
        if column_index is not None and 0 <= column_index < len(self.result_tree["columns"]):
            menu.add_command(label="Копировать ячейку", command=lambda: self.copy_search_cell(item, column_index))
            menu.add_command(label="Копировать строку", command=lambda: self.copy_search_row(item))
        menu.post(event.x_root, event.y_root)

    def copy_search_cell(self, item, column_index):
        values = self.result_tree.item(item, "values")
        if values and column_index < len(values):
            self.root.clipboard_clear()
            self.root.clipboard_append(str(values[column_index]))

    def copy_search_row(self, item):
        values = self.result_tree.item(item, "values")
        if values:
            row_text = "\t".join(str(v) for v in values)
            self.root.clipboard_clear()
            self.root.clipboard_append(row_text)

    def copy_search_selected_row(self, event):
        selected = self.result_tree.selection()
        if selected:
            self.copy_search_row(selected[0])

