# ========== ФУНКЦИИ ДЛЯ КОПИРОВАНИЯ/ВСТАВКИ (исправлены) ==========
_last_paste_time = 0
_paste_delay = 0.1

def copy_text(widget):
    """Копировать выделенный текст в буфер обмена"""
    try:
        if widget.selection_present():
            widget.clipboard_clear()
            widget.clipboard_append(widget.selection_get())
    except:
        pass

def cut_text(widget):
    """Вырезать выделенный текст в буфер обмена"""
    try:
        if widget.selection_present():
            widget.clipboard_clear()
            widget.clipboard_append(widget.selection_get())
            widget.delete(tk.SEL_FIRST, tk.SEL_LAST)
    except:
        pass

def paste_text(widget):
    """Вставить текст из буфера обмена, заменяя выделение"""
    global _last_paste_time
    now = time.time()
    if now - _last_paste_time < _paste_delay:
        return  # защита от повторной вставки
    _last_paste_time = now
    try:
        # Если есть выделение, удаляем его
        if widget.selection_present():
            widget.delete(tk.SEL_FIRST, tk.SEL_LAST)
        # Вставляем текст
        text = widget.clipboard_get()
        widget.insert(tk.INSERT, text)
    except:
        pass

def enable_copy_paste(widget):
    """Добавляет привязки клавиш для копирования/вставки/вырезания"""
    if not hasattr(widget, '_copy_paste_enabled'):
        widget.bind("<Control-c>", lambda e: (copy_text(widget), "break"))
        widget.bind("<Control-Insert>", lambda e: (copy_text(widget), "break"))
        widget.bind("<Control-v>", lambda e: (paste_text(widget), "break"))
        widget.bind("<Shift-Insert>", lambda e: (paste_text(widget), "break"))
        widget.bind("<Control-x>", lambda e: (cut_text(widget), "break"))
        widget._copy_paste_enabled = True


