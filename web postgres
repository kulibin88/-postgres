            self.cur.execute("""
                SELECT sequencename, last_value, start_value, increment_by
                FROM pg_sequences
                WHERE schemaname = %s
                ORDER BY sequencename
            """, (schema,))
            sequences = self.cur.fetchall()
            if not sequences:
                messagebox.showinfo("Информация", "Нет последовательностей в схеме.")
                return
            dialog = tk.Toplevel(self.root)
            dialog.transient(self.root)
            dialog.attributes('-topmost', True)
            dialog.after(200, lambda: dialog.attributes('-topmost', False))
            dialog.title(f"Последовательности в схеме {schema}")
            dialog.geometry("700x400")

            tree = ttk.Treeview(dialog, columns=("name", "last", "start", "increment"),
                show="headings", height=15)
            tree.heading("name", text="Имя")
            tree.heading("last", text="Последнее значение")
            tree.heading("start", text="Начальное значение")
            tree.heading("increment", text="Шаг")
            tree.column("name", width=200)
            tree.column("last", width=150)
            tree.column("start", width=150)
            tree.column("increment", width=100)
