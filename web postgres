        self.db_entry = ttk.Entry(self.root, textvariable=self.db_var, width=30)
        self.db_entry.grid(row=2, column=1, padx=5, pady=5)
        enable_copy_paste(self.db_entry)

        ttk.Label(self.root, text="Пользователь:").grid(row=3, column=0, padx=5, pady=5, sticky="e")
        self.user_entry = ttk.Entry(self.root, textvariable=self.user_var, width=30)
        self.user_entry.grid(row=3, column=1, padx=5, pady=5)
        enable_copy_paste(self.user_entry)

        ttk.Label(self.root, text="Пароль:").grid(row=4, column=0, padx=5, pady=5, sticky="e")
        self.pwd_entry = ttk.Entry(self.root, textvariable=self.pwd_var, width=30, show="*")
        self.pwd_entry.grid(row=4, column=1, padx=5, pady=5)
        enable_copy_paste(self.pwd_entry)

        ttk.Button(self.root, text="Подключиться", command=self.connect).grid(row=5, column=0, columnspan=2, pady=10)

        self.save_var = tk.BooleanVar(value=True)
        ttk.Checkbutton(self.root, text="Сохранить параметры", variable=self.save_var).grid(row=6, column=0, columnspan=2)

        self.root.mainloop()

    def load_config(self):
        if os.path.exists(CONFIG_FILE):
            self.config.read(CONFIG_FILE)
        else:
            self.config["DB"] = {}

    def save_config(self):
        if self.save_var.get():
            self.config["DB"] = {
                "host": self.host_var.get(),
                "port": self.port_var.get(),
                "database": self.db_var.get(),
                "user": self.user_var.get(),
                "password": self.pwd_var.get()
            }
            with open(CONFIG_FILE, "w") as f:
                self.config.write(f)

    def connect(self):
        try:
            conn = psycopg2.connect(
                host=self.host_var.get(),
                port=self.port_var.get(),
                dbname=self.db_var.get(),
                user=self.user_var.get(),
                password=self.pwd_var.get()
            )
            conn.autocommit = False
            self.save_config()
            self.root.destroy()
            MainWindow(conn)
        except Exception as e:
            messagebox.showerror("Ошибка подключения", f"Не удалось подключиться:\n{e}")


