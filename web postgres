    def create_table(self):
        table_name = self.create_table_name_var.get().strip()
        schema_name = self.create_schema_var.get().strip()
        if not table_name:
            messagebox.showwarning("Предупреждение", "Введите название таблицы.")
            return
        if not schema_name:
            messagebox.showwarning("Предупреждение", "Выберите схему.")
            return
        columns = []
        for name_entry, type_combo, constraint_combo, _ in self.column_entries:
            col_name = name_entry.get().strip()
            col_type = type_combo.get()
            constraint = constraint_combo.get()
            if not col_name:
                messagebox.showwarning("Предупреждение", "Все колонки должны иметь имя.")
                return
            if col_type in ["SERIAL", "BIGSERIAL"]:
                col_def = f"{col_name} {col_type}"
                if constraint == "PRIMARY KEY":
                    col_def += " PRIMARY KEY"
            else:
                col_def = f"{col_name} {col_type}"
                if constraint != "None":
                    col_def += f" {constraint}"
            columns.append(col_def)
        if not columns:
            messagebox.showwarning("Предупреждение", "Добавьте хотя бы одну колонку.")
            return
        query = sql.SQL("CREATE TABLE {}.{} ({})").format(
            sql.Identifier(schema_name),
            sql.Identifier(table_name),
            sql.SQL(", ").join(sql.SQL(col) for col in columns)
        )
        try:
            with self.conn:
                self.cur.execute(query)
            messagebox.showinfo("Успех", f"Таблица '{schema_name}.{table_name}' создана.")
            self.load_view_objects(self.schema_combo.get())
            self.load_manage_tables()
            self.load_tables_for_data_schema(self.data_schema_combo.get())
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось создать таблицу:\n{e}")

