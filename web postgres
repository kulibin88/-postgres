    def load_create_schemas(self):
        try:
            cur = self.conn.cursor()
            cur.execute("""
                SELECT schema_name
                FROM information_schema.schemata
                WHERE schema_name NOT IN ('pg_catalog', 'information_schema')
                AND schema_name NOT LIKE 'pg_temp%'
                AND schema_name NOT LIKE 'pg_toast%'
                ORDER BY schema_name
            """)
            schemas = [row[0] for row in cur.fetchall()]
            cur.close()
            self.create_schema_combo['values'] = schemas
            if schemas:
                self.create_schema_combo.current(0)
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить список схем:\n{e}")

    def load_manage_schemas(self):
        try:
            cur = self.conn.cursor()
            cur.execute("""
                SELECT schema_name
                FROM information_schema.schemata
                WHERE schema_name NOT IN ('pg_catalog', 'information_schema')
                AND schema_name NOT LIKE 'pg_temp%'
                AND schema_name NOT LIKE 'pg_toast%'
                ORDER BY schema_name
            """)
            schemas = [row[0] for row in cur.fetchall()]
            cur.close()
            self.manage_schema_combo['values'] = schemas
            if schemas:
                self.manage_schema_combo.current(0)
                self.load_manage_tables()
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить список схем:\n{e}")

    def load_manage_tables(self, event=None):
        schema = self.manage_schema_combo.get()
        if not schema:
            return
        try:
            cur = self.conn.cursor()
            cur.execute("""
                SELECT table_name
                FROM information_schema.tables
                WHERE table_schema = %s
                AND table_type = 'BASE TABLE'
                ORDER BY table_name
            """, (schema,))
            tables = [row[0] for row in cur.fetchall()]
            cur.close()
            self.manage_table_combo['values'] = tables
            if tables:
                self.manage_table_combo.current(0)
                self.load_table_columns()
            else:
                self.manage_table_combo.set('')
                self.columns_tree.delete(*self.columns_tree.get_children())
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить список таблиц:\n{e}")

    def load_table_columns(self):
        schema = self.manage_schema_combo.get()
        table = self.manage_table_combo.get()
        if not schema or not table:
            return
        try:
            self.cur.execute("""
                SELECT column_name, data_type, is_nullable, column_default
                FROM information_schema.columns
                WHERE table_schema = %s AND table_name = %s
                ORDER BY ordinal_position
            """, (schema, table))
            cols = self.cur.fetchall()
            self.columns_tree.delete(*self.columns_tree.get_children())
            for col in cols:
                constraints = self.get_column_constraints(schema, table, col[0])
                self.columns_tree.insert("", "end", values=(col[0], col[1], col[2], col[3] or "", constraints))
            self.conn.commit()
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось загрузить структуру таблицы:\n{e}")

    def get_column_constraints(self, schema, table, column):
        try:
            self.cur.execute("""
                SELECT tc.constraint_type
                FROM information_schema.table_constraints tc
                JOIN information_schema.key_column_usage kcu
                ON tc.constraint_name = kcu.constraint_name
                WHERE tc.table_schema = %s AND tc.table_name = %s AND kcu.column_name = %s
            """, (schema, table, column))
            constraints = [row[0] for row in self.cur.fetchall()]
            self.cur.execute("""
                SELECT is_nullable
                FROM information_schema.columns
                WHERE table_schema = %s AND table_name = %s AND column_name = %s
            """, (schema, table, column))
            is_nullable = self.cur.fetchone()[0]
            if is_nullable == 'NO':
                constraints.append('NOT NULL')
            return ', '.join(constraints) if constraints else ''
        except:
            return ''

    def delete_table(self):
        schema = self.manage_schema_combo.get()
        table = self.manage_table_combo.get()
        if not schema or not table:
            messagebox.showwarning("Предупреждение", "Выберите таблицу для удаления.")
            return
        if not messagebox.askyesno("Подтверждение", f"Удалить таблицу {schema}.{table}?\nЭто действие необратимо!"):
            return
        try:
            with self.conn:
                self.cur.execute(sql.SQL("DROP TABLE {}.{} CASCADE").format(sql.Identifier(schema), sql.Identifier(table)))
            messagebox.showinfo("Успех", f"Таблица {schema}.{table} удалена.")
            self.load_manage_tables()
            self.load_view_objects(self.schema_combo.get())
            self.load_tables_for_data_schema(self.data_schema_combo.get())
        except Exception as e:
            self.conn.rollback()
            messagebox.showerror("Ошибка", f"Не удалось удалить таблицу:\n{e}")

    def add_column(self):
