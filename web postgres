            if type_combo.get() == "CHECK":
                check_entry.config(state="normal")
                col_combo.config(state="normal")
                if not constraint_name_entry.get():
                    constraint_name_entry.insert(0, f"check_{table}_{col_combo.get()}")
                check_hint_label.config(text=f"Пример: > 0  →  CHECK ({col_combo.get()} > 0)")
            else:
                check_entry.config(state="disabled")
                check_hint_label.config(text="")
                if not constraint_name_entry.get():
                    constraint_name_entry.insert(0, f"{type_combo.get().lower()}_{table}_{col_combo.get()}")

        type_combo.bind("<<ComboboxSelected>>", toggle_check)
        col_combo.bind("<<ComboboxSelected>>", lambda e: toggle_check())

