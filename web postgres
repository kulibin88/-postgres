                self.conn.rollback()
                messagebox.showerror("Ошибка", f"Ограничение с именем '{cons_name}' уже существует.\nВыберите другое имя.")
            except Exception as e:
                self.conn.rollback()
                messagebox.showerror("Ошибка", f"Не удалось добавить ограничение:\n{e}")

